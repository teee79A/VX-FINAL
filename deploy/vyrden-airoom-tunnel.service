[Unit]
Description=Cloudflare Tunnel for vyrden.com AI Room
After=network-online.target vyrden-airoom.service
Wants=network-online.target
Requires=vyrden-airoom.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/cloudflared tunnel --config /etc/cloudflared/vyrden-airoom.yml run
Restart=always
RestartSec=5
Environment=NO_AUTOUPDATE=true

[Install]
WantedBy=multi-user.target
